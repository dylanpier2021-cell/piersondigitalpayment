# Copy this file to .env to override defaults. All values are optional.

# Port the server listens on.
PORT=4242

# Secret used to sign session cookies. Change this in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Transfado platform (admin) login created on first seed.
ADMIN_EMAIL=owner@transfado.com
ADMIN_PASSWORD=transfado123

# Set to "live" to disable the simulated card network. Not implemented yet —
# the platform ships in "sandbox" mode using a built-in mock card processor.
PROCESSING_MODE=sandbox
