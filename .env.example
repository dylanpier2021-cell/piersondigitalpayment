# Copy this file to .env to override defaults. All values are optional.

# Port the server listens on.
PORT=4242

# Secret used to sign session cookies. Change this in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Demo admin login created on first seed.
ADMIN_EMAIL=owner@transfado.com
ADMIN_PASSWORD=transfado123

# Platform OWNER / super-admin (Earnings page, $0 fees, withdraws platform profit).
OWNER_EMAIL=dylanpier2021@gmail.com
OWNER_PASSWORD=owner1234

# Persistent database directory. Point at a mounted disk in production so real
# accounts survive restarts (e.g. /var/data on Render). Unset = ./data locally,
# or /tmp on Vercel (ephemeral — re-seeds on cold start).
# TF_DATA_DIR=/var/data

# Seed rich demo merchants/transactions. Set to "false" for a clean production
# platform so real signups start empty (only owner + admin + plans + coupons).
SEED_DEMO=true

# Transactional email (verification / reset / welcome). Leave unset to run in
# sandbox (logs the email + returns the reset link). Set to enable real sending.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Transfado <no-reply@transfado.com>

# Set to "live" to disable the simulated card network. Not implemented yet —
# the platform ships in "sandbox" mode using a built-in mock card processor.
PROCESSING_MODE=sandbox
